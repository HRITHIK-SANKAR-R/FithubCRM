<?xml version="1.0" encoding="UTF-8"?>
<ValidationRule xmlns="http://soap.sforce.com/2006/04/metadata">
    <fullName>Status_Confirmation_Validation_Rule</fullName>
    <active>true</active>
    <errorConditionFormula>AND(
    ISPICKVAL(Status__c, &quot;Confirmed&quot;),
    NOT(ISPICKVAL(Payment_Status__c, &quot;Paid&quot;))
)</errorConditionFormula>
    <errorMessage>Booking cannot be confirmed until payment status is marked as &apos;Paid&apos;.</errorMessage>
</ValidationRule>
